---
import MainLayout from '../layouts/MainLayout.astro';
import Cursor from '../components/Cursor.astro';
import Navbar from '../components/Navbar.astro';
import CursorToggle from '../components/CursorToggle.astro';
import Menu from '../components/Menu.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
// Pulizia base path per i file statici
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
---

<MainLayout>
    <Cursor />
    <Navbar />
    <CursorToggle />
    <Menu page="mofont"/>
  
  <main class="specimen-page">
    <section class="specimen-hero">
      <div class="specimen-header">
        <div class="meta-info">
          <span class="label">Mofont</span>
          <span class="label">v1.0 / 2026</span>
        </div>
        <h1 class="font-title">MoFont</h1>
        <p class="font-intro">
          Un font nato dal design del mio logo.
          Progettato per titoli e, in generale, per l'uso in maiuscolo.
          Scaricalo gratis con licenza OFL e usalo nei tuoi progetti personali e commerciali!
        </p>
      </div>

      <div class="tester-container">
        <textarea 
          id="typeTester" 
          spellcheck="false" 
          placeholder="Digita per testare..."
        >PROVALO QUI...</textarea>
        
        <div class="tester-footer">
  <div class="slider-group">
    <span class="label">Size</span>
    <input type="range" id="sizeSlider" min="40" max="350" value="180" />
    <span id="sizeValue" class="label">180px</span>
  </div>

  <a href={`${cleanBase}/downloads/MoFont_v1.zip`} download class="btn-download">
    Download MoFont
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M19 12l-7 7-7-7"/>
    </svg>
  </a>
  
  <div class="footer-spacer"></div>
</div>
      </div>
    </section>
  </main>
    <ContactSection />
  <Footer />
</MainLayout>

<style>
  /* --- SETUP FONT --- */
  @font-face {
    font-family: 'MoFont';
    src: url('/fonts/MoFont.woff2') format('woff2'); /* Assicurati che sia in public/fonts/ */
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  body{
    background-color: var(--dark-text);
  }

  .specimen-page {
    background-color: var(--dark-text);
    color: var(--text-light);
    padding: 140px 20px 80px;
    
    margin: 0 auto;
  }

  /* --- TESTI NORMALI (INTER) --- */
  .font-intro {
    font-family: 'JetBrains Mono', sans-serif;
    font-size: 18px;
    line-height: 1.5;
    max-width: 600px;
    opacity: 1;
    margin-top: 20px;
  }

  /* --- METADATI (JETBRAINS MONO) --- */
  .label, .code, .meta-info, #sizeValue {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-gold);
  }

  .meta-info {
    display: flex;
    gap: 20px;
    margin-bottom: 10px;
  }

  /* --- TITOLI E TESTER (MOFONT) --- */
  .font-title {
    font-family: 'Inter', sans-serif;
    font-size: clamp(40px, 8vw, 80px);
    margin: 0;
    line-height: 0.9;
    color: var(--accent-coral);
    text-transform: uppercase;
     /* Aggiunta di un leggero effetto neon */
  }

  .tester-container {
    margin-top: 80px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  #typeTester {
    width: 100%;
    min-height: 400px;
    background: transparent;
    border: none;
    color: var(--text-light);
    font-family: 'MoFont', sans-serif;
    font-size: 180px;
    text-align: center;
    outline: none;
    resize: none;
    padding: 60px 0;
    line-height: 1;
  }

  /* --- CONTROLLI --- */
  .tester-footer {
    display: grid;
    /* Dividiamo in 3 colonne: Slider, Bottone (Centro), Spazio vuoto */
    grid-template-columns: 1fr auto 1fr; 
    align-items: center;
    padding: 40px 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .slider-group {
    display: flex;
    align-items: center;
    gap: 15px;
    justify-self: start;
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    border: 1px solid var(--accent-gold);
    color: var(--accent-gold);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    justify-self: center; /* Centra il bottone nella colonna centrale */
  }

  .btn-download svg {
    transition: transform 0.3s ease;
  }

  .btn-download:hover {
    background: var(--accent-gold);
    color: var(--dark-text);
  }

  .btn-download:hover svg {
    transform: translateY(3px); /* Effetto rimbalzo verso il basso */
  }

  /* Responsive */
  @media (max-width: 900px) {
    .tester-footer {
      display: flex;
      flex-direction: column;
      gap: 40px;
    }
    .slider-group, .btn-download {
      justify-self: center;
    }
  }
</style>

<script>
  const tester = document.getElementById('typeTester');
  const slider = document.getElementById('sizeSlider');
  const sizeVal = document.getElementById('sizeValue');

  slider?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value;
    if(tester) tester.style.fontSize = `${val}px`;
    if(sizeVal) sizeVal.textContent = `${val}px`;
  });
</script>