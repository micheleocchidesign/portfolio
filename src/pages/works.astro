---
import MainLayout from '../layouts/MainLayout.astro';
import PageTransition from '../components/PageTransition.astro';
import Cursor from '../components/Cursor.astro';
import Navbar from '../components/Navbar.astro';
import CursorToggle from '../components/CursorToggle.astro';
import Menu from '../components/Menu.astro';
import InkFlooding from '../components/InkFlooding.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import WorksIntro from '../components/works/WorksIntro.astro';
import WorksGrid from '../components/works/WorksGrid.astro';
/* LOGICA CMS */
import { getCollection } from 'astro:content';
const allProjects = await getCollection('works');
const projects = allProjects
  .sort((a, b) => {
    // Ordiniamo per il numero 'order'
    // Se i numeri sono uguali, ordiniamo per titolo (alfabetico) come paracadute
    if (a.data.order !== b.data.order) {
      return a.data.order - b.data.order;
    }
    return a.data.title.localeCompare(b.data.title);
  })
  .map(project => ({
    ...project.data,
    slug: project.id,
    href: project.data.externalLink || `/works/${project.id}/`
  }));
---
<MainLayout>
	<PageTransition />	
    <Cursor />
    <Navbar />
    <CursorToggle />
    <Menu page="works"/>
    <WorksIntro />
    <InkFlooding color="var(--text-light)" />
    <WorksGrid projects={projects} />
    <ContactSection />
    <Footer />    
</MainLayout>

<style>
    body {
        background-color: var(--dark-text);
    }
</style>