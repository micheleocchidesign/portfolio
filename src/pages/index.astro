---
import MainLayout from '../layouts/MainLayout.astro';
import PageTransition from '../components/PageTransition.astro';
import Cursor from '../components/Cursor.astro';
import Navbar from '../components/Navbar.astro';
import CursorToggle from '../components/CursorToggle.astro';
import Menu from '../components/Menu.astro';
import HeroLogo from '../components/HeroLogo.astro';
import InkFlooding from '../components/InkFlooding.astro';
import BeyondSection from '../components/BeyondSection.astro';
import WorksSection from '../components/WorksSection.astro';
import AboutSection from '../components/AboutSection.astro';
import AmoSection from '../components/AmoSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import { gsap } from "gsap";
---
<MainLayout>
	<PageTransition />	
    <Cursor />
    <Navbar />
    <CursorToggle />
    <Menu page="home"/>
    <HeroLogo />
    <InkFlooding color="var(--dark-text)" />
    <BeyondSection />
    <WorksSection />
    
    <div id="about-amo-wrapper">
        <AboutSection />
        <AmoSection />
    </div>
    <ContactSection />
    <Footer />    
</MainLayout>
<script>
    window.addEventListener('load', () => {
    if (window.location.hash) {
        const target = window.location.hash;
        // Reset istantaneo in alto per evitare il salto del browser
        window.scrollTo(0, 0); 
        
        // Scroll fluido dopo un piccolo delay per far caricare il resto
        gsap.to(window, { 
            duration: 1.5, 
            scrollTo: target, 
            ease: "power2.inOut", 
            delay: 0.5 
        });
    }
});
</script>