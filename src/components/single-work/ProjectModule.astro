---
import { Image } from 'astro:assets';

const { 
  moduleType,          
  type: manualType,    
  format,        
  variant,       
  url,           // Questo ora può essere un OGGETTO (Immagine src) o STRINGA (Video/Public)
  youtubeId,     
  link,          
  title,
  showControls = false 
} = Astro.props;

// 1. NORMALIZZAZIONE TIPO
const type = moduleType || manualType;

// 2. LOGICA PERCORSO AGGIORNATA
// Se url è un oggetto, Astro ha già fatto tutto (ottimizzazione + percorso).
// Se è una stringa, dobbiamo aggiungere il base path (per i video in public).
const isOptimizedImage = typeof url === 'object';

const getStaticPath = (path) => {
    // Se è un oggetto o un link esterno, non toccarlo
    if (typeof path === 'object' || !path || path.startsWith('http')) return path;
    
    const rawBase = import.meta.env.BASE_URL;
    const cleanBase = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
    
    // Rimuoviamo eventuali prefissi "/src" che potrebbero arrivare dal CMS
    // perché i file statici devono stare in /public
    const cleanPath = path.replace(/^\/?src\//, '/').startsWith('/') ? path : `/${path}`;

    return `${cleanBase}${cleanPath}`.replace(/\/+/g, '/');
};

// Se è un'immagine ottimizzata, usiamo 'url' così com'è. 
// Se è un video o altro, usiamo il path statico con il base URL.
const finalSrc = isOptimizedImage ? url : getStaticPath(url);

const ytControls = showControls ? '1' : '0';
const isShort = variant === "short";

const iframeClass = 
    format === 'vertical' ? 'iframe-contain' : 
    format === 'square' ? 'iframe-square' : 
    'iframe-cover';
---

<div class={`module module--${format} type-${type} ${youtubeId ? 'module--video-embed' : ''}`}>
    
    {/* --- CASO 1: IMMAGINI --- */}
    {type === "image" && (
        link ? (
            <a href={link} target="_blank" class="module-link">
                {typeof finalSrc === 'object' ? (
                    <Image src={finalSrc} alt={title || ""} width={1600} height={1200} />
                ) : (
                    <img src={finalSrc} alt={title} loading="lazy" />
                )}
            </a>
        ) : (
            typeof finalSrc === 'object' ? (
                <Image src={finalSrc} alt={title || ""} width={1600} height={1200} />
            ) : (
                <img src={finalSrc} alt={title} loading="lazy"/>
            )
        )
    )}

    {/* --- CASO 2: FILE VIDEO (MP4) --- */}
    {type === "video" && (
        /* Applichiamo il link SOLO se è short E c'è un link */
        (isShort && link) ? (
            <a href={link} target="_blank" class="module-link video-short-link">
                <video 
                    src={typeof finalSrc === 'string' ? finalSrc : finalSrc.src} 
                    autoplay 
                    loop 
                    muted 
                    playsinline 
                    class={format === 'vertical' ? 'object-contain' : 'object-cover'}
                />
                <div class="video-hover-overlay"></div>
            </a>
        ) : (
            /* Video standard (lungo o senza link): mantiene i controlli se non è short */
            <video 
                src={typeof finalSrc === 'string' ? finalSrc : finalSrc.src} 
                autoplay={isShort} 
                loop={isShort} 
                muted={isShort} 
                controls={!isShort} 
                playsinline={true}
                class={format === 'vertical' ? 'object-contain' : 'object-cover'}
            />
        )
    )}

    {/* --- CASO 3: YOUTUBE --- */}
    {type === "youtube" && (
        <div class="video-container">
            <iframe 
                src={`https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0&modestbranding=1&controls=${ytControls}${isShort ? `&autoplay=1&mute=1&loop=1&playlist=${youtubeId}&playsinline=1` : ''}`}
                title="YouTube video player"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen
                class={iframeClass}
            ></iframe>
        </div>
    )}
</div>

<style>
    .module {
    position: relative;
    background: #000; /* Nero per i margini dei video story */
    overflow: hidden;
    width: 100%;
}

/* Formati del Container */
.module--square { aspect-ratio: 1 / 1; }
.module--horizontal { grid-column: 1 / -1; aspect-ratio: 16 / 9; }
.module--vertical { aspect-ratio: 4 / 5; }

/* Comportamento Media standard */
.module img, 
.module video, 
.module .video-container {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover; /* Riempie sempre lo spazio */
}

/* Gestione speciale Video STORY (9:16) dentro modulo VERTICALE (4:5) */
/* Usiamo una classe 'object-contain' per non tagliare il video */
.module video.object-contain,
.module .iframe-contain {
    object-fit: contain !important; 
    background: var(--text-light); /* Colore di sfondo per evitare bordi neri evidenti */
}

/* Fix per IFRAME YouTube per essere responsivi */
.video-container {
    position: relative;
}

.video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
}

/* Immagini con Link */
.module-link {
    display: block;
    width: 100%;
    height: 100%;
}

/* YouTube Quadrato (1:1) */
.module--square .video-container iframe.iframe-square {
    object-fit: cover; /* Riempie il quadrato */
    width: 100%;
    height: 100%;
}

/* YouTube Story (9:16) dentro modulo Verticale (4:5) */
.module--vertical .video-container iframe.iframe-contain {
    object-fit: contain !important;
    height: 100%;
    width: auto;
    aspect-ratio: 9 / 16;
    left: 50%;
    transform: translateX(-50%);
}

/* Assicuriamoci che i moduli video con controlli mostrino il cursore standard 
   (Riprendendo il debugging di prima) */
.type-youtube, .type-video {
    cursor: auto !important;
}

.video-short-link {
        display: block;
        width: 100%;
        height: 100%;
        cursor: pointer !important; /* La manina faticata! */
        position: relative;
    }

    .video-hover-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0);
        transition: background 0.3s ease;
        pointer-events: none; /* Non deve bloccare il click al link */
    }

    /* Feedback discreto: schiarisce o scurisce leggermente al passaggio */
    .video-short-link:hover .video-hover-overlay {
        background: rgba(255, 255, 255, 0.05);
    }

    /* Se il video NON è linkato (caso else), assicurati che il cursore torni default */
    video:not(.video-short-link video) {
        cursor: auto;
    }
</style>