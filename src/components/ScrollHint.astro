---
// 1. Importiamo il componente Icon
import { Icon } from 'astro-icon/components';
// Riceviamo l'ID della sezione di destinazione del click (es. "#beyond-section")
const { target } = Astro.props;
---

<div class="scroll-hint">
  <a href={target} class="internal-scroll-link">
    <span class="hint-text">KEEEEEEP</span>
    <Icon name="arrow_cool_down" class="icon-scroll" aria-hidden="true" />
    <span class="hint-text">SCROLLIN'</span>
  </a>
</div>

<style>
/* --- SCROLL HINT ARROW --- */
.scroll-hint {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    animation: scrollBounce 2s infinite;
    white-space: nowrap;
}

/* Usiamo i font locali che abbiamo configurato */
.hint-text {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    font-weight: 400;
    opacity: 0.8;
}

.internal-scroll-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    cursor: pointer !important;
}

/* Gestione dell'icona SVG locale */
.icon-scroll {
    width: 28px;
    height: 28px;
    display: block;
    /* Se il tuo SVG è nero e lo vuoi bianco, usa filter */
    filter: invert(1); 
}

@keyframes scrollBounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
}

@media (max-width: 768px) {
    .scroll-hint {
        bottom: 15dvh; 
    }
}
</style>

<script>
  // Importiamo GSAP correttamente per Astro
  import { gsap } from "gsap";
  import { ScrollToPlugin } from "gsap/ScrollToPlugin";

  if (typeof window !== "undefined") {
    gsap.registerPlugin(ScrollToPlugin);
  }

  function handleScroll(e) {
    e.preventDefault();
    const href = e.currentTarget.getAttribute('href');
    
    if (href && href.startsWith('#')) {
      gsap.to(window, { 
        duration: 1.5, 
        scrollTo: { y: href, autoKill: true }, 
        ease: "power3.inOut" 
      });
    }
  }

  function initScrollHints() {
    const scrollLinks = document.querySelectorAll('.internal-scroll-link');
    scrollLinks.forEach(link => {
      link.removeEventListener('click', handleScroll);
      link.addEventListener('click', handleScroll);
    });
  }

  // Supporto per navigazione standard e Astro View Transitions
  initScrollHints();
  document.addEventListener('astro:page-load', initScrollHints);
</script>