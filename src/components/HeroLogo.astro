---
import MoLogo from "../components/MoLogo.astro"
import ScrollHint from "../components/ScrollHint.astro"
---
<section class="hero-container">
    <div id="hero-logo-wrapper">
        <MoLogo MaskId="m-hero"/> 
        <div class="hero-text">
                <h1 class="hero-title">Michele Occhi</h1>
                <p class="hero-subtitle jetbrains">Full-Stack Creative</p>
            </div>
    </div>
    <div id="gyro-cta">
        <div class="phone-icon"></div><span></span>
    </div>
    <ScrollHint target="#beyond-section" color="var(--dark-text)" />
</section>

<style>
.hero-container {
    height: 100vh;
    position: relative;
    z-index: 1;
}
 #hero-logo-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 480px;
    max-width: 85vw;
    z-index: 5;
    transition: transform 0.9s cubic-bezier(0.85, 0, 0.15, 1);
}

.hero-text {
    margin-top: 40px; /* Spazio tra logo e testi */
    text-align: center;
}

.hero-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 20px;
    font-weight: 800;
    color: var(--dark-text);
    margin: 0;
    letter-spacing: .1em;
    line-height: 1;
}

.hero-subtitle {
    /* La classe .jetbrains è già definita nel tuo global.css */
    font-size: 14px;
    color: var(--dark-text);
    font-weight: 400;
    letter-spacing: .08em;
    margin-top: 8px;
}
</style>