---
import MoLogo from '../components/MoLogo.astro';

// Astro gestisce già la base. Se sei su GitHub sarà "/portfolio", 
// se sei in locale sarà "".
const rawBase = import.meta.env.BASE_URL;
// Puliamo la base per evitare // se rawBase è "/"
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

// Creiamo il link alla home pulito. 
// Se base finisce già con "/", non aggiungiamo nulla.
const homeLink = base.endsWith('/') ? base : `${base}/`;

const { disableLogoScroll = false } = Astro.props;
---

<header id="site-header" data-disable={disableLogoScroll.toString()}>
    <a id="nav-logo-wrapper" href={homeLink}>
        <MoLogo MaskId="m-nav"/>
    </a>
    <a id="label-name" class="ui-label" href={homeLink}>Michele Occhi</a>
    <div id="nav-text-menu" class="ui-label">Menu +</div>
</header>

<style>
    /* 1. REGOLA NUCLEARE: Forza la manina su tutti gli elementi della nav */
    /* Usiamo :global(html:not(...) body) per avere una specificità imbattibile */
    :global(html:not(.use-standard-cursor) body) #nav-logo-wrapper,
    :global(html:not(.use-standard-cursor) body) #label-name,
    :global(html:not(.use-standard-cursor) body) #nav-text-menu {
        cursor: pointer !important;
        pointer-events: auto !important;
    }

    .ui-label {
        position: fixed;
        z-index: 10001;
        font-family: 'JetBrains Mono';
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #fff;
        mix-blend-mode: difference;
        transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), color 0.3s ease;
        line-height: 1;
        /* Assicuriamoci che non erediti il cursor: none */
        cursor: pointer !important;
        pointer-events: auto !important;
    }

    #label-name {
        top: 45px;
        left: 35px;
        text-align: center;
        text-decoration: none !important;
        cursor: pointer !important;
    }
 #label-name.scrolled {
    transform: translateY(60px);
}
 #nav-text-menu {
    top: 45px;
    right: 35px;
    padding: 30px;
   /* Espande l'area sensibile in ogni direzione */
    margin: -30px;
   /* Annulla lo spostamento visivo causato dal padding */
    cursor: pointer !important;
   /* Aggiungi queste due righe per sicurezza */
    display: flex;
    align-items: center;
    justify-content: center;
}
 #nav-text-menu.sticky-active {
    color: var(--text-light);
    mix-blend-mode: normal;
}
/* Estensione della label per coprire l'intera pillola */
 .full-clickable-label {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    width: 100%;
    height: 100%;
    padding: 5px 10px;
   /* Spostiamo il padding qui per massimizzare l'area */
}

/* --- LOGOS --- */
 #nav-logo-wrapper {
    position: fixed;
    top: 25px;
    left: 35px;
    width: 110px;
    z-index: 10001;
    transform: translateY(-150%);
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
    cursor: pointer !important;
}
 #nav-logo-wrapper.slide-in {
    transform: translateY(0);
    opacity: 1;
}
</style>

<script>
    // @ts-ignore
    const gsap = window.gsap;

    function isHomePage(href: string) {
        const cleanPath = (path: string) => path.replace(/^\/|\/$/g, '');
        const current = cleanPath(window.location.pathname);
        const target = cleanPath(href);
        const base = cleanPath(import.meta.env.BASE_URL);

        // Ritorna true se il target è uguale al path corrente o alla base del sito
        return target === current || target === base || (target === '' && (current === base || current === ''));
    }

    function initNavbar() {
        const nLog = document.getElementById('nav-logo-wrapper');
        const labelName = document.getElementById('label-name');
        const menuBtn = document.getElementById('nav-text-menu');
        const overlay = document.getElementById('menu-overlay');
        const header = document.getElementById('site-header');

        // 1. GESTIONE SCROLL
        if (header?.dataset.disable !== "true") {
            window.addEventListener('scroll', () => {
                const isScrolled = window.scrollY > 100;
                nLog?.classList.toggle('slide-in', isScrolled);
                labelName?.classList.toggle('scrolled', isScrolled);
            }, { passive: true });
        }

        // 2. LOGICA MENU (Usiamo addEventListener invece di .onclick per evitare errori di target)
        const toggleMenu = () => {
            const isOpen = document.body.classList.toggle('menu-open');
            overlay?.classList.toggle('active');
            if (menuBtn) menuBtn.innerText = isOpen ? 'Close —' : 'Menu +';
        };

        menuBtn?.addEventListener('click', toggleMenu);

        // 3. CLICK SUI LINK DEL MENU
        document.querySelectorAll('.menu-link').forEach(link => {
            link.addEventListener('click', (e) => {
                const href = link.getAttribute('href');
                if (!href) return;

                const isAnchor = href.startsWith('#');
                const isCurrentPageAnchor = href.includes('#') && isHomePage(href.split('#')[0]);

                if (isAnchor || isCurrentPageAnchor) {
                    const targetId = href.split('#').pop();
                    const targetElem = document.getElementById(targetId || '');

                    if (targetElem) {
                        e.preventDefault();
                        toggleMenu();
                        if (gsap) {
                            gsap.to(window, { duration: 1.5, scrollTo: targetElem, ease: "power2.inOut", delay: 0.2 });
                        } else {
                            targetElem.scrollIntoView({ behavior: 'smooth' });
                        }
                    }
                }
            });
        });

        // 4. CLICK SU LOGO/NOME
        [nLog, labelName].forEach(el => {
            el?.addEventListener('click', (e) => {
                const rawBase = import.meta.env.BASE_URL;
                const cleanBase = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
                
                // Verifichiamo se siamo effettivamente nella ROOT (Home)
                // Il path della home può essere "" o "/" o "/portfolio"
                const currentPath = window.location.pathname.replace(/\/$/, ""); // Rimuove slash finale
                const isActuallyInHome = currentPath === cleanBase || currentPath === (cleanBase || "/");

                if (isActuallyInHome) {
                    // Se siamo già in Home, scorri solo su
                    e.preventDefault();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                } 
                // Altrimenti, NON fare nulla: lascia che il browser segua l'href del link
            });
        });
    }

    // Inizializzazione sicura
    initNavbar();
    document.addEventListener('astro:page-load', initNavbar);
</script>