---
import { Icon } from 'astro-icon/components';
---
<section id="contact-section">
    <div class="contact-main">
        <p class="contact-intro">
            Che tu sia un’agenzia, un'azienda o un privato, se&nbsp;hai un'idea, le diamo forma. <br>
            Se hai dubbi su come posso aiutarti,
        </p>

        <h2 class="collab-title">
            <a href="mailto:hello@micheleocchi.com" class="scrivimi-link">scrivimi!</a>
        </h2>

        <div class="email-block">
            <div class="email-wrapper">
                <a href="mailto:hello@micheleocchi.com" class="email-link">hello@micheleocchi.com</a>
                
                <button class="copy-btn" id="copy-btn" aria-label="Copy email">
                    <Icon name="content_copy" class="icon-copy" />
                    <Icon name="check" class="icon-check" />
                </button>
            </div>
            <p class="email-hint">
                Se non hai un programma di posta configurato, copia l'indirizzo e scrivimi manualmente.
            </p>
        </div>
    </div>
</section>

<style>
    #contact-section {
    background-color: var(--text-light);
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
   /* Centra il blocco "collaboriamo" */
    align-items: center;
    position: relative;
    padding: 60px;
    box-sizing: border-box;
    z-index: 11;
    color: var(--dark-text);
}
 .contact-intro {
    font-family:"Jetbrains Mono", monospace;
    text-align: center;
    margin-inline: auto;
    color: var(--dark-text);
    font-size: clamp(16px, 1.5vw, 20px);
    line-height: 1.6;
    max-width: 600px;
   /* Mantiene il testo compatto */
}
 .collab-title {
    font-family: "MoFont", sans-serif;
    font-size: clamp(50px, 10vw, 130px);
    text-transform: uppercase;
    margin:0;
    margin-bottom: 20px;
    line-height: 1;
    color: var(--accent-coral);
    text-align: center;
}
 .scrivimi-link {
    color: inherit;
   /* Eredita il colore dal h2 */
    text-decoration: none;
   /* Toglie la sottolineatura standard */
    transition: opacity 0.3s ease;
    display: inline-block;
    cursor: pointer !important;
}
 .email-block {
    text-align: center;
    font-family: "JetBrains Mono", monospace;
}
 .email-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}
 .email-wrapper a{
    cursor:pointer !important;
}

.copy-btn {
        background: none;
        border: none;
        cursor: pointer;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .copy-btn :global(svg) {
        width: 24px;
        height: 24px;
        position: absolute;
        transition: opacity 0.2s ease, transform 0.2s ease;
        /* Assicuriamoci che prendano il colore del testo */
        fill: currentColor; 
    }

    .icon-check { 
        opacity: 0; 
        transform: scale(0.5); 
    }

    /* Quando il genitore ha la classe success, cambiano le immagini */
    .copy-btn.copy-success .icon-copy { opacity: 0; transform: scale(0.5); }
    .copy-btn.copy-success .icon-check { opacity: 1; transform: scale(1); }

    .copy-btn::after {
    content: 'Copiato!';
    position: absolute;
    bottom: 120%; /* Lo posiziona sopra il bottone */
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background-color: var(--accent-coral);
    color: var(--text-light); /* Testo chiaro su fondo corallo */
    padding: 5px 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: 10;
}

/* Triangolino sotto il tooltip */
.copy-btn::before {
    content: '';
    position: absolute;
    bottom: 110%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    border-width: 5px;
    border-style: solid;
    border-color: var(--accent-coral) transparent transparent transparent;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 10;
}

/* MOSTRA TOOLTIP quando c'è successo */
.copy-btn.copy-success::after,
.copy-btn.copy-success::before {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
}

 .email-link {
    font-size: 4vw;
    text-decoration: none;
    color: inherit;
    font-weight: 500;
    transition: opacity 0.3s;
}
 .email-link:hover {
    text-decoration: underline;
}

.email-hint {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--dark-text);
    opacity: 0.5; /* Lo rende discreto */
    margin-top: 15px;
    max-width: 800px;
    margin-inline: auto;
    line-height: 1.4;
}
</style>

<script>
    function copyEmail() {
        const email = "hello@micheleocchi.com";
        // CERCHIAMO .copy-btn (non .copy-icon che non esiste più)
        const btn = document.getElementById('copy-btn');
        if (!btn) return;

        const showSuccess = () => {
            btn.classList.add('copy-success');
            setTimeout(() => {
                btn.classList.remove('copy-success');
            }, 1500);
        };

        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(email)
                .then(showSuccess)
                .catch(() => fallbackCopy(email, showSuccess));
        } else {
            fallbackCopy(email, showSuccess);
        }
    }

    function fallbackCopy(text: string, callback: () => void): void {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        textArea.style.position = "fixed";
        textArea.style.left = "-9999px";
        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();
        try {
            document.execCommand('copy');
            callback();
        } catch (err) {
            console.error('Errore copia:', err);
        }
        document.body.removeChild(textArea);
    }

    function initContactCopy() {
        const copyBtn = document.getElementById('copy-btn');
        if (copyBtn) {
            copyBtn.removeEventListener('click', copyEmail);
            copyBtn.addEventListener('click', copyEmail);
        }
    }

    initContactCopy();
    document.addEventListener('astro:page-load', initContactCopy);
</script>